{
  "format": "LS_GIZMO_V1",
  "name": "merlin",
  "description": "Development gizmo for Merlin, a geared mock detector for agent-written patches.",
  "gadgets": {
    "core": {
      "root": "tools/merlin",
      "language": "python",
      "target_ref": "origin/gadgets/merlin/core/main",
      "integration_branch": "gadgets/merlin/core/main",
      "agent_branch_template": "gadget-agents/merlin/core/{agent}",
      "owned_paths": [
        "tools/merlin/",
        "docs/merlin/",
        "examples/gizmos/merlin.gizmo.json"
      ],
      "verification_profiles": {
        "quick": [
          "python -m py_compile tools/merlin/merlin/__init__.py tools/merlin/merlin/detector.py tools/merlin/merlin/cli.py tools/merlin/test/smoke.py"
        ],
        "full": [
          "python tools/merlin/test/smoke.py"
        ]
      },
      "commands": {
        "scan": "python -m merlin.cli scan {path} --out {out}",
        "scan-strict": "python -m merlin.cli scan {path} --out {out} --fail-on-issues"
      }
    }
  },
  "imports": {}
}
